RewriteEngine On

# Tell the Node backend the original public host + scheme. The expr= prefix
# evaluates an Apache 2.4 expression at request time. Wrapped in IfModule so
# the file doesn't 500 if mod_headers is missing.
<IfModule mod_headers.c>
    RequestHeader set X-Forwarded-Host "expr=%{HTTP_HOST}"
    RequestHeader set X-Forwarded-Proto "expr=%{REQUEST_SCHEME}"
</IfModule>

# Forward /api/* to the Node backend (PM2-managed) on the loopback interface.
# Port matches PORT in the server's .env file.
RewriteRule ^api/(.*)$ http://127.0.0.1:8088/api/$1 [P,L]

# SPA fallback: any non-file, non-directory request serves index.html so
# wouter's client-side routes (e.g. /books/123) don't 404.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
